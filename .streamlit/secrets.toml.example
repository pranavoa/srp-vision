# Copy to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored — never commit real credentials.
#
# Streamlit Community Cloud: paste these key=value pairs into the
# "Secrets" section of the app settings UI (no file needed).

ES_URL = "https://your-cluster.aws.elastic-cloud.com:443"
ES_INDEX = "search-master-hotel-details-test"
ES_API_KEY = ""

# Optional — legacy single-password gate (unused once Google auth is on below).
APP_PASSWORD = ""

# Optional — Google OIDC auth. When the [auth] block is present and complete,
# the app requires Google sign-in restricted to the allowed_domain set in app.py
# (default: onarrival.travel). Leave commented out to disable.
#
# [auth]
# redirect_uri        = "https://<your-app>.streamlit.app/oauth2callback"
# cookie_secret       = "<random 32+ char string>"
# client_id           = "<from Google Cloud Console>"
# client_secret       = "<from Google Cloud Console>"
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

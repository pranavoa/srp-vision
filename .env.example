# Copy to .env and fill in real values, OR put the same keys in
# .streamlit/secrets.toml (preferred for Streamlit Community Cloud).
#
# .env is gitignored — never commit real credentials.

ES_URL=https://your-cluster.aws.elastic-cloud.com:443
ES_INDEX=search-master-hotel-details-test
ES_API_KEY=

# Optional — when set, the app shows a password gate before any data is loaded.
APP_PASSWORD=
